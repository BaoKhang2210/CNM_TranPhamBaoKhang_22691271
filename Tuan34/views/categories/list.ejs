<%- include('../layout/header') %>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Categories</h2>
    <a href="/categories/create" class="btn btn-success">Add New Category</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Description</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        <% if (categories.length > 0) { %>
            <% categories.forEach(category => { %>
                <tr>
                    <td><%= category.name %></td>
                    <td><%= category.description %></td>
                    <td>
                        <form action="/categories/delete/<%= category.categoryId %>" method="POST" class="d-inline" onsubmit="return confirm('Are you sure? This will NOT delete associated products.');">
                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                        </form>
                    </td>
                </tr>
            <% }); %>
        <% } else { %>
            <tr>
                <td colspan="3" class="text-center">No categories found.</td>
            </tr>
        <% } %>
    </tbody>
</table>

<%- include('../layout/footer') %>
