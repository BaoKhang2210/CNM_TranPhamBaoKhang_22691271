<%- include('../layout/header') %>

<h2><%= product ? 'Edit Product' : 'Create Product' %></h2>

<form action="<%= product ? '/products/edit/' + product.id : '/products/create' %>" method="POST" enctype="multipart/form-data">
    <div class="mb-3">
        <label for="name" class="form-label">Product Name</label>
        <input type="text" class="form-control" id="name" name="name" value="<%= product ? product.name : '' %>" required>
    </div>
    
    <div class="mb-3">
        <label for="price" class="form-label">Price</label>
        <input type="number" step="0.01" class="form-control" id="price" name="price" value="<%= product ? product.price : '' %>" required>
    </div>
    
    <div class="mb-3">
        <label for="quantity" class="form-label">Quantity</label>
        <input type="number" class="form-control" id="quantity" name="quantity" value="<%= product ? product.quantity : '' %>" required>
    </div>
    
    <div class="mb-3">
        <label for="categoryId" class="form-label">Category</label>
        <select class="form-select" id="categoryId" name="categoryId" required>
            <option value="" disabled <%= !product ? 'selected' : '' %>>Select a category</option>
            <% categories.forEach(cat => { %>
                <option value="<%= cat.categoryId %>" <%= (product && product.categoryId === cat.categoryId) ? 'selected' : '' %>>
                    <%= cat.name %>
                </option>
            <% }); %>
        </select>
    </div>
    
    <div class="mb-3">
        <label for="image" class="form-label">Product Image</label>
        <% if (product && product.url_image) { %>
            <div class="mb-2">
                <img src="<%= product.url_image %>" alt="Current Image" width="100">
                <small class="text-muted d-block">Current Image</small>
            </div>
        <% } %>
        <input type="file" class="form-control" id="image" name="image" accept="image/*" <%= !product ? 'required' : '' %>>
        <% if (product) { %>
            <div class="form-text">Leave blank to keep current image.</div>
        <% } %>
    </div>
    
    <button type="submit" class="btn btn-primary"><%= product ? 'Update Product' : 'Create Product' %></button>
    <a href="/products" class="btn btn-secondary">Cancel</a>
</form>

<%- include('../layout/footer') %>
