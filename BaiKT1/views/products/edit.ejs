<h2>Sửa sản phẩm</h2>

<form method="POST" enctype="multipart/form-data">
    <input type="hidden" name="oldImage" value="<%= product.url_image %>">

    Tên: <input name="name" value="<%= product.name %>"><br>
    Giá: <input name="price" value="<%= product.price %>"><br>
    Kho: <input name="unit_in_stock" value="<%= product.unit_in_stock %>"><br>

    <img src="<%= product.url_image %>" width="100"><br>

    Ảnh mới: <input type="file" name="image"><br>

    <button>Cập nhật</button>
</form>